# HireStack AI - Backend Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME=HireStack AI
DEBUG=true
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000

# CORS
# NOTE: Include both localhost + 127.0.0.1 to avoid dev CORS mismatches.
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:3002","http://127.0.0.1:3002"]
ALLOWED_ORIGINS=http://localhost:3002,http://127.0.0.1:3002

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Redis (for caching and rate limiting)
REDIS_URL=redis://localhost:6379

# AI Provider — "gemini", "openai", or "ollama"
AI_PROVIDER=gemini

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-5.2
OPENAI_MAX_TOKENS=4096

# Gemini
# Google AI Studio API key (recommended for local dev; usually starts with "AIza…")
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_TOKENS=8192
# Throttle Gemini requests to avoid free-tier 429s (set to 0 to disable).
GEMINI_MIN_INTERVAL_MS=3500

# Gemini via Vertex AI (OAuth) — alternative to API key
# NOTE: Vertex AI does NOT accept API keys. You must configure OAuth credentials.
GEMINI_USE_VERTEXAI=false
GEMINI_VERTEX_PROJECT=your-gcp-project-id
GEMINI_VERTEX_LOCATION=us-central1
# Example OAuth setup:
#   export GOOGLE_APPLICATION_CREDENTIALS="/absolute/path/to/service-account.json"

# Ollama (local LLM) — best fallback when cloud quotas are exhausted
# Requires: `ollama serve` and a pulled model (e.g. `ollama pull qwen3:4b`)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_MAX_TOKENS=1024

# File Upload
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=./uploads

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

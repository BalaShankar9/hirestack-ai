{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hirestack.ai/events/v1/generation.requested.v1.schema.json",
  "title": "GenerationRequestedV1",
  "description": "Emitted when an application's generation pipeline is enqueued.",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_type", "event_version", "payload"],
  "properties": {
    "event_type": { "const": "generation.requested" },
    "event_version": { "const": 1 },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["job_id", "application_id", "user_id", "requested_modules"],
      "properties": {
        "job_id":            { "type": "string", "format": "uuid" },
        "application_id":    { "type": "string", "format": "uuid" },
        "user_id":           { "type": "string", "format": "uuid" },
        "requested_modules": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}

<?xml version="1.0" encoding="utf-8"?>
<!--
  HireStack adaptive-icon foreground.
  Adaptive icons are 108dp wide; the safe inner zone is the centre 72dp circle.
  We render a bold "HS" wordmark inside the safe zone on a transparent
  foreground (background supplied by colors.xml ic_launcher_background).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- H – left letter -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M30,32 h8 v18 h12 v-18 h8 v44 h-8 v-18 h-12 v18 h-8 z" />

    <!-- S – right letter, drawn as two stacked rounded bars -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M62,40 c0,-5 4,-9 9,-9 h7 v8 h-7 c-1,0 -1,1 -1,1 v6 c0,1 0,1 1,1 h6 c5,0 9,4 9,9 v6 c0,5 -4,9 -9,9 h-7 v-8 h7 c1,0 1,-1 1,-1 v-6 c0,-1 0,-1 -1,-1 h-6 c-5,0 -9,-4 -9,-9 z" />
</vector>

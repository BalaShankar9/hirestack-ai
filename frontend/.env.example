# Frontend Environment Variables
# Copy to .env.local and fill in your values

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend API
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_AI_ENABLED=true

# AI streaming timeouts (ms) — increase if using a local LLM (Ollama).
NEXT_PUBLIC_AI_HARD_TIMEOUT_MS=1800000
NEXT_PUBLIC_AI_INACTIVITY_TIMEOUT_MS=900000

# Realtime subscriptions (Supabase Realtime). Set to "true" to enable; otherwise polling is used.
NEXT_PUBLIC_ENABLE_REALTIME=false

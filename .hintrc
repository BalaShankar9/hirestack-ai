{
  "extends": ["development"],
  "hints": {
    "no-inline-styles": "off",
    "meta-theme-color": "off",
    "apple-touch-icons": "off",
    "axe/name-role-value": "off",
    "axe/aria": "off",
    "axe/forms": "off",
    "axe/language": "off",
    "axe/parsing": "off",
    "axe/semantics": "off",
    "axe/text-alternatives": "off",
    "axe/keyboard": "off",
    "axe/other": "off",
    "compat-api/css": "off",
    "compat-api/html": "off"
  },
  "ignoredUrls": [
    ".*\\.worktrees/.*",
    ".*\\.next/.*",
    ".*node_modules.*"
  ]
}
